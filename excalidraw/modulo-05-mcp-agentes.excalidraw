    {
      "id": "m52c8b3d1694b45b3",
      "type": "text",
      "x": 1161,
      "y": 480.01171875,
      "width": 667.4560546875,
      "height": 48.75,
      "text": "IA - \"preciso ver o chamado 1234 do sigaa e identificar a possível causa do problema\"\nCliente \"preciso encontrar a lista de chamados, retornar o conteudo do chamado 1234\"\nServer \"traz os chamados filtrados pelo id 1234\"   -> IA começa a analisar o codebase com o contexto do chamado\"",
      "fontSize": 13,
      "strokeColor": "#495057",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 844857618,
      "updated": 1783871498587,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 581,
      "index": "aU",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "IA - \"preciso ver o chamado 1234 do sigaa e identificar a possível causa do problema\"\nCliente \"preciso encontrar a lista de chamados, retornar o conteudo do chamado 1234\"\nServer \"traz os chamados filtrados pelo id 1234\"   -> IA começa a analisar o codebase com o contexto do chamado\""
    },
