    {
      "id": "m59fe2ecdfa994ddf",
      "type": "text",
      "x": 65.49377912858284,
      "y": 2018,
      "width": 891.3457641601562,
      "height": 73.9132187112127,
      "text": "MCP = tomada universal para ferramentas externas (dados que mudam)  |  \nAgente = cérebro + mãos + memória + guardrails  |  \nLoop = planejar → executar → observar → replanejar  |  Skill ≠ MCP ≠ API — cada um tem seu papel.",
      "fontSize": 19.71019165632339,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 772123534,
      "updated": 1783873799728,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 38,
      "index": "b0j",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "MCP = tomada universal para ferramentas externas (dados que mudam)  |  \nAgente = cérebro + mãos + memória + guardrails  |  \nLoop = planejar → executar → observar → replanejar  |  Skill ≠ MCP ≠ API — cada um tem seu papel."
    },
