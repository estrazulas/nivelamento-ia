    {
      "id": "m5699e59024044ff9",
      "type": "text",
      "x": 60,
      "y": 135,
      "width": 357.54205322265625,
      "height": 42.5,
      "text": "❌ Prompt Direto com PRD (doc de requisitos) \nGigante",
      "fontSize": 17,
      "strokeColor": "#e03131",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1925163334,
      "updated": 1783958283590,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 28,
      "index": "a4",
      "strokeWidth": 2,
      "strokeStyle": "solid",
