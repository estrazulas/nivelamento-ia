      "y": 1172,
      "width": 204.16,
      "height": 21.6,
      "text": "🎯 Por que RPI importa:",
      "fontSize": 16,
      "strokeColor": "#7950f2",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
