    {
      "id": "m0e8285f3abb54449",
      "type": "text",
      "x": 530,
      "y": 855,
      "width": 305.65999999999997,
      "height": 22.950000000000003,
      "text": "📚 Documentação como Combustível",
      "fontSize": 17,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1431366726,
      "updated": 1783882821552,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 2,
      "index": "ao",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
