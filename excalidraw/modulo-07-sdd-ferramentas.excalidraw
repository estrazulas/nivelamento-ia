    },
    {
      "id": "m8101e93dfd0c4186",
      "type": "text",
      "x": 60,
      "y": 888,
      "width": 335.60390625,
      "height": 468.688213900862,
      "text": "O STATE.md guarda:\n• Decisões tomadas e POR QUÊ\n• Tasks concluídas e pendentes\n• Blockers e dependências\n• Aprendizados e descobertas\n\nQuando você volta (5 minutos ou\n5 dias depois), o agente lê o\nSTATE.md e continua de onde parou.\n\nProblema que resolve:\nO MAIOR problema de desenvolver\ncom IA: perda de contexto entre\nsessões. Sem STATE.md, cada nova\nconversa começa do zero.\n\n📖 Analogia:\nDiário de obra. O pedreiro do turno\nseguinte lê e sabe exatamente o\nque foi feito, o que falta e quais\ndecisões foram tomadas.",
      "fontSize": 16.532212130541872,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [
        {
          "id": "qmmpF6VArt6QwjmdcIFlb",
          "type": "arrow"
        }
      ],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 840704198,
      "updated": 1783960133646,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 53,
      "index": "am",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "O STATE.md guarda:\n• Decisões tomadas e POR QUÊ\n• Tasks concluídas e pendentes\n• Blockers e dependências\n• Aprendizados e descobertas\n\nQuando você volta (5 minutos ou\n5 dias depois), o agente lê o\nSTATE.md e continua de onde parou.\n\nProblema que resolve:\nO MAIOR problema de desenvolver\ncom IA: perda de contexto entre\nsessões. Sem STATE.md, cada nova\nconversa começa do zero.\n\n📖 Analogia:\nDiário de obra. O pedreiro do turno\nseguinte lê e sabe exatamente o\nque foi feito, o que falta e quais\ndecisões foram tomadas."
    },
