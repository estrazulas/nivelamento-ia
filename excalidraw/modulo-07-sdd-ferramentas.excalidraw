    {
      "id": "m20f079e74ffa4d72",
      "type": "text",
      "x": 60,
      "y": 855,
      "width": 325.38,
      "height": 22.950000000000003,
      "text": "📝 STATE.md: Memória Entre Sessões",
      "fontSize": 17,
      "strokeColor": "#4c6ef5",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "backgroundColor": "transparent",
      "fillStyle": "solid"
    },
    {
      "id": "m8101e93dfd0c4186",
      "type": "text",
      "x": 60,
      "y": 888,
      "width": 243.6,
      "height": 340.20000000000005,
      "text": "O STATE.md guarda:\n• Decisões tomadas e POR QUÊ\n• Tasks concluídas e pendentes\n• Blockers e dependências\n• Aprendizados e descobertas\n\nQuando você volta (5 minutos ou\n5 dias depois), o agente lê o\nSTATE.md e continua de onde parou.\n\nProblema que resolve:\nO MAIOR problema de desenvolver\ncom IA: perda de contexto entre\nsessões. Sem STATE.md, cada nova\nconversa começa do zero.\n\n📖 Analogia:\nDiário de obra. O pedreiro do turno\nseguinte lê e sabe exatamente o\nque foi feito, o que falta e quais\ndecisões foram tomadas.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "backgroundColor": "transparent",
      "fillStyle": "solid"
    },
    {
      "id": "mddc610da0ee04080",
      "type": "rectangle",
      "x": 510,
      "y": 840,
      "width": 440,
      "height": 520,
      "backgroundColor": "#f0fff4",
      "strokeColor": "#b2f2bb",
      "strokeWidth": 2,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
