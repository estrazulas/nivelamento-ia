      "width": 325.38,
      "height": 22.950000000000003,
      "text": "📝 STATE.md: Memória Entre Sessões",
      "fontSize": 17,
      "strokeColor": "#4c6ef5",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
