      "type": "text",
      "x": 1160,
      "y": 1302,
      "width": 633.3599999999999,
      "height": 17.55,
      "text": "🔄 O ciclo completo: SDD define as 4 fases do projeto. Em cada fase, você aplica RPI.",
      "fontSize": 13,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
