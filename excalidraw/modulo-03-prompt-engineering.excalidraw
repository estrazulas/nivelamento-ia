    {
      "id": "TLdew_h84EWf_6C_oiFWx",
      "type": "text",
      "x": -576.0543572443186,
      "y": 934.9906072443222,
      "width": 496.061639366728,
      "height": 518.1995738636361,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
