    {
      "id": "mN9htSSFztk6q5rnhdwkb",
      "type": "text",
      "x": 2183.23,
      "y": 611.0109375,
      "width": 596.8992919921875,
      "height": 378,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1R",
      "roundness": null,
      "seed": 1786710083,
      "version": 159,
      "versionNonce": 1941709357,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783691324018,
      "link": null,
      "locked": false,
      "text": "\"Você é o pizzaiolo responsável pela produção de massas frescas\"\n                                      → ROLE\n\"Calcule quantas massas preparar para hoje\"\n                                      → INSTRUCTION\n\"1. Veja o dia da semana (terça ≠ sexta)\n 2. Confira se tem evento grande na cidade\n 3. Olhe a previsão do tempo\n 4. Compare com o histórico do mesmo dia nas últimas 4 semanas\n 5. Adicione 10% de margem de segurança\"\n                                      → STEPS\n\"Uma planilha com: número de massas, justificativa pra cada fator,\nmargem de segurança aplicada, e o número final\"\n                                      → EXPECTED\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Você é o pizzaiolo responsável pela produção de massas frescas\"\n                                      → ROLE\n\"Calcule quantas massas preparar para hoje\"\n                                      → INSTRUCTION\n\"1. Veja o dia da semana (terça ≠ sexta)\n 2. Confira se tem evento grande na cidade\n 3. Olhe a previsão do tempo\n 4. Compare com o histórico do mesmo dia nas últimas 4 semanas\n 5. Adicione 10% de margem de segurança\"\n                                      → STEPS\n\"Uma planilha com: número de massas, justificativa pra cada fator,\nmargem de segurança aplicada, e o número final\"\n                                      → EXPECTED\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
