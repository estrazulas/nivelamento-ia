      "type": "text",
      "x": 1155,
      "y": 885,
      "width": 549.8399999999999,
      "height": 16.200000000000003,
      "text": "10 comandos num prompt só → o modelo prioriza os primeiros e ignora os últimos.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
