    {
      "id": "m7ceaf3649830401e",
      "type": "text",
      "x": 1605,
      "y": 885,
      "width": 598.56,
      "height": 16.200000000000003,
      "text": "\"Melhore esse código\" → o modelo não sabe se é performance, legibilidade ou segurança.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "backgroundColor": "transparent",
      "fillStyle": "solid"
    },
    {
      "id": "m5d7179dc46d04785",
      "type": "text",
      "x": 1605,
      "y": 940,
      "width": 612.4799999999999,
      "height": 16.200000000000003,
      "text": "Fix: Especifique a dimensão. Ex: \"Melhore a performance reduzindo alocações de memória.\"",
      "fontSize": 12,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
