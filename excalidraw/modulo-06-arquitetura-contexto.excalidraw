    {
      "id": "m02130de07523481c",
      "type": "text",
      "x": 530.9161931818181,
      "y": 1660.0142045454545,
      "width": 165.74985795454552,
      "height": 25,
      "text": "👷 SUB-AGENT",
      "fontSize": 20,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": false,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1067009305,
      "updated": 1783879226921,
      "backgroundColor": "transparent",
