      "y": 855,
      "width": 256.35999999999996,
      "height": 22.950000000000003,
      "text": "✅ Com Skill Jira Assistant",
      "fontSize": 17,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
