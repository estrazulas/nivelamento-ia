    {
      "id": "m02130de07523481c",
      "type": "text",
      "x": 530,
      "y": 1660,
      "width": 127.6,
      "height": 27.0,
      "text": "👷 SUB-AGENT",
      "fontSize": 20,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
