    {
      "id": "m1fcee6c3169d4d46",
      "type": "text",
      "x": 1160,
      "y": 890,
      "width": 208.79999999999998,
      "height": 145.8,
      "text": "O dev diz:\n\"Corrige o bug CAN-123 na URL\ntechleads.atlassian.net, cloud\ndigital, board CAN, instância\nAtlas...\"\n\nToda vez: escrever headers,\ntokens, query params, IDs.\nSujeito a erro de digitação.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
