    {
      "id": "m1fcee6c3169d4d46",
      "type": "text",
      "x": 1160,
      "y": 890,
      "width": 376.23773193359375,
      "height": 147.4810606060606,
      "text": "O dev diz:\n\"Cria a ISSUE 1234 no gitlab para melhorar a performace\ndo ProcessadorXyz do SIGAA\"\n\nToda vez: vai criar um template aleatório de issue\nperguntar token do gitlab. \npesquisar em todos os projetos do gilab para identificar\no sigaa e criar a issue",
      "fontSize": 14.74810606060606,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
