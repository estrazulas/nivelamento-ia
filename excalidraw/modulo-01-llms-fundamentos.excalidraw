    {
      "id": "mf377ffd73c854282",
      "type": "text",
      "x": 52.03125,
      "y": 2012.015625,
      "width": 865.0361200968412,
      "height": 58.00390624999991,
      "text": "Pré-treinamento = Chef formado (base)    |    Fine-Tuning = Especialização cara em sushi    |    RAG = Receita na mão do chef\n\nVantagens do RAG: Mais barato • Mais rápido • Mais fácil de atualizar • Sem retreino • Fácil de debugar",
      "fontSize": 15.467708333333304,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
