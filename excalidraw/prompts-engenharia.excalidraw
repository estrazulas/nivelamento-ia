    {
      "id": "mrcghj56tg5db5ky9w",
      "type": "text",
      "x": 75,
      "y": 1028,
      "text": "Exemplo 2 — Script AWS com boto3:\n\n\"Crie um script Python que provisione:\nVPC, subnets, Internet Gateway,\nSecurity Group e EC2 t3.micro\"\n\n✅ Gera código funcional\n⚠️ Mas sem convenções do time (tags,\nnomes, estrutura de módulos)",
      "fontSize": 12,
      "angle": 0,
      "opacity": 100,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
