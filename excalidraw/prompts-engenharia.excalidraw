    {
      "id": "mrcgvh1lxvw6mbdj1br",
      "type": "text",
      "x": 1140,
      "y": 1795,
      "text": "🔍 K8s Events  →  🧠 CoT/ReAct  →  🔧 kubectl fix  →  ✅ Re-verify  →  💬 Discord Embed\n     (detectar)      (diagnosticar)     (corrigir)         (validar)        (comunicar)",
      "fontSize": 13,
      "angle": 0,
      "opacity": 100,
      "roundness": null,
