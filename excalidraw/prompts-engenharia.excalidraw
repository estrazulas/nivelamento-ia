    {
      "id": "mrcgvh2wdann2ilt677",
      "type": "text",
      "x": 1135,
      "y": 1875,
      "strokeColor": "#495057",
      "text": "Exemplo real — 1 único prompt:",
      "fontSize": 13,
      "angle": 0,
      "opacity": 100,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "fillStyle": "solid",
