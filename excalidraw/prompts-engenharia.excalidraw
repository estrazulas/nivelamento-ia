    {
      "id": "mrcgh8bjqgyfduhon2j",
      "type": "text",
      "x": 60,
      "y": 740,
      "text": "🎯 Zero-shot vs Few-shot: Instruir ou Mostrar?",
      "fontSize": 26,
      "angle": 0,
      "opacity": 100,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
