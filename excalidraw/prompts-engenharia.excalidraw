      "x": 1595,
      "y": 1085,
      "strokeColor": "#7950f2",
      "text": "4. Filtrar — \"Só o que importa agora\"",
      "fontSize": 15,
      "angle": 0,
      "opacity": 100,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
