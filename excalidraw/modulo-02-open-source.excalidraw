    {
      "id": "upkydenD_cyIAekiooexQ",
      "type": "text",
      "x": 2283.4581399204912,
      "y": 599.570601514666,
      "width": 720.579345703125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
