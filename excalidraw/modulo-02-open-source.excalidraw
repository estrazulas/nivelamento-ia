    {
      "id": "meecec7c96b404d96",
      "type": "text",
      "x": 1160,
      "y": 168,
      "width": 292.32,
      "height": 291.6,
      "text": "Ollama está pra LLM assim como Docker\nestá pra aplicação — baixa e roda com\num comando, sem depender de internet.\n\nInstalação:\n  brew install ollama  (macOS)\n  apt-get install ollama  (Linux)\n\nUso:\n  ollama run llama3.2\n  ollama run qwen2.5:7b\n\nVantagens:\n✅ Sem API key — execução 100% local\n✅ Dados não saem da máquina\n✅ Ideal para testar e comparar modelos\n\nAnalogia: Docker pull + run, mas pra LLMs.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "backgroundColor": "transparent",
      "fillStyle": "solid"
    },
