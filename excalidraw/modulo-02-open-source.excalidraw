      "y": 1160,
      "width": 185.6,
      "height": 21.6,
      "text": "Quando Usar Cada Um:",
      "fontSize": 16,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
