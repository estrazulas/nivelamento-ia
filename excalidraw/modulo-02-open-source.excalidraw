    },
    {
      "id": "m84dafa0a2511402b",
      "type": "text",
      "x": 60,
      "y": 1190,
      "width": 528.9599999999999,
      "height": 145.8,
      "text": "SLM Local (latência mínima, custo zero):\n  • Sumarização de logs e documentos    • Classificação de tickets e e-mails\n  • Parsing de dados estruturados        • Autocomplete e sugestões simples\n  • Extração de entidades\n\nLLM Cloud (raciocínio complexo, pontual):\n  • Design de arquitetura de software    • Debugging multi-arquivo\n  • Geração de documentação técnica     • Análise de vulnerabilidades\n  • Tradução e refatoração complexa",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1088697189,
      "updated": 1783603753821,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 2,
      "index": "ab",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "SLM Local (latência mínima, custo zero):\n  • Sumarização de logs e documentos    • Classificação de tickets e e-mails\n  • Parsing de dados estruturados        • Autocomplete e sugestões simples\n  • Extração de entidades\n\nLLM Cloud (raciocínio complexo, pontual):\n  • Design de arquitetura de software    • Debugging multi-arquivo\n  • Geração de documentação técnica     • Análise de vulnerabilidades\n  • Tradução e refatoração complexa"
    },
