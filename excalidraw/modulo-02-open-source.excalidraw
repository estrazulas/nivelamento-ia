      "width": 156.6,
      "height": 24.3,
      "text": "🏪 Proprietários",
      "fontSize": 18,
      "strokeColor": "#4c6ef5",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
