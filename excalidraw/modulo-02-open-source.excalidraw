    {
      "id": "mce9a63cc68aa4aad",
      "type": "text",
      "x": 60,
      "y": 135,
      "width": 135.72,
      "height": 24.3,
      "text": "🍳 Open-Source",
      "fontSize": 18,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
