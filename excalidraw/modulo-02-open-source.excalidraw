    {
      "id": "mde21f49b1db04e00",
      "type": "text",
      "x": 1160,
      "y": 135,
      "width": 281.88,
      "height": 24.3,
      "text": "🦙 Ollama: O Eletrodoméstico",
      "fontSize": 18,
      "strokeColor": "#4c6ef5",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
