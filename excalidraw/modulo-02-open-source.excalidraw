      "version": 93,
      "width": 265,
      "height": 350,
      "fontFamily": 2,
      "fontSize": 11,
      "text": "┌─────────────────────────────────────┐\n│ Cabeçalho:                          │\n│   type: \"llama\"                     │\n│   layers: 32                        │\n│   dim: 4096                         │\n│   vocab: 128.256 tokens             │\n│   input: texto (sequência de tokens)│\n│   output: distribuição sobre tokens │\n├─────────────────────────────────────┤\n│                                     │\n│   -0.0034  0.0156 -0.0089  0.0214  │\n│    0.0182 -0.0067  0.0113 -0.0198  │\n│    0.0055 -0.0124 -0.0017  0.0160  │\n│    ...                              │\n│    (8 bilhões de números)           │\n│                                     │\n│    ↓ o que cada número significa?   │\n│    \"rei - homem + mulher ≈ rainha\"  │\n│    \"Paris - França + Japão ≈ Tóquio\"│\n│    \"código Python usa indentação\"   │\n│    \"perto de SELECT vem FROM\"       │\n│    ...                             │\n└─────────────────────────────────────┘",
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeColor": "#333",
      "index": "b1W",
      "id": "8HGUsu7_WqE1IRjSjExXa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "backgroundColor": "transparent",
      "link": null,
      "containerId": null,
      "originalText": "┌─────────────────────────────────────┐\n│ Cabeçalho:                          │\n│   type: \"llama\"                     │\n│   layers: 32                        │\n│   dim: 4096                         │\n│   vocab: 128.256 tokens             │\n│   input: texto (sequência de tokens)│\n│   output: distribuição sobre tokens │\n├─────────────────────────────────────┤\n│                                     │\n│   -0.0034  0.0156 -0.0089  0.0214  │\n│    0.0182 -0.0067  0.0113 -0.0198  │\n│    0.0055 -0.0124 -0.0017  0.0160  │\n│    ...                              │\n│    (8 bilhões de números)           │\n│                                     │\n│    ↓ o que cada número significa?   │\n│    \"rei - homem + mulher ≈ rainha\"  │\n│    \"Paris - França + Japão ≈ Tóquio\"│\n│    \"código Python usa indentação\"   │\n│    \"perto de SELECT vem FROM\"       │\n│    ...                             │\n└─────────────────────────────────────┘"
    },
