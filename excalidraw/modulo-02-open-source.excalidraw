    {
      "id": "mb45c3d33809f4522",
      "type": "text",
      "x": 1630,
      "y": 135,
      "width": 354.96,
      "height": 22.950000000000003,
      "text": "🤗 Hugging Face: O GitHub dos Modelos",
      "fontSize": 17,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
