    {
      "id": "m6bcfe57f5f0344e5",
      "type": "text",
      "x": 60,
      "y": 1608,
      "width": 761.54,
      "height": 35.1,
      "text": "Mais que o modelo escolhido. Contexto RUIM + GPT-4o perde para contexto BOM + GPT-3.5.\nO contexto certo transforma a mesma pergunta e o mesmo modelo em resultados completamente diferentes.",
      "fontSize": 13,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1887538681,
      "updated": 1783706760531,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 2,
      "index": "b0L",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "Mais que o modelo escolhido. Contexto RUIM + GPT-4o perde para contexto BOM + GPT-3.5.\nO contexto certo transforma a mesma pergunta e o mesmo modelo em resultados completamente diferentes."
    },
