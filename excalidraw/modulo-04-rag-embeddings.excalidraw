      "type": "text",
      "x": 1160,
      "y": 488,
      "width": 879.6237037037029,
      "height": 70.59999999999998,
      "text": "Chunks = Fichas catalográficas        Embeddings = Coordenadas da estante\nVector DB = Sistema de busca           Similaridade = Encontrar livros na mesma estante\nInjeção = Colocar os livros abertos na mesa do aluno",
      "fontSize": 17.432098765432094,
      "strokeColor": "#495057",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
