      "fillStyle": "solid"
    },
    {
      "id": "m1d5531ea519644ef",
      "type": "text",
      "x": 530,
      "y": 168,
      "width": 306.23999999999995,
      "height": 226.8,
      "text": "Fluxo:\n  Pergunta → Busca docs relevantes\n          → LLM (com contexto)\n          → Resposta baseada em fontes\n\n✅ Vantagens:\n• Respostas baseadas em dados reais\n• Fontes citáveis e auditáveis\n• Atualização fácil (reindexa, não retreina)\n• Domínio específico sem fine-tuning\n\nAnalogia:\nAluno com livro aberto na página certa —\nconsulta a fonte e responde com precisão.",
      "fontSize": 12,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1,
      "updated": 1,
      "backgroundColor": "transparent",
      "fillStyle": "solid"
    },
