      "y": 855,
      "width": 125.27999999999999,
      "height": 24.3,
      "text": "🕸️ Graph RAG",
      "fontSize": 18,
      "strokeColor": "#7950f2",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
