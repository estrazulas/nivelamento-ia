      "y": 855,
      "width": 177.48,
      "height": 24.3,
      "text": "📄 RAG Tradicional",
      "fontSize": 18,
      "strokeColor": "#fd7e14",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
