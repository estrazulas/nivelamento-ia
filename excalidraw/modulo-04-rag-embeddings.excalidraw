    {
      "id": "maa69370dca654371",
      "type": "text",
      "x": 60,
      "y": 135,
      "width": 285.94,
      "height": 22.950000000000003,
      "text": "❌ Sem RAG — Confia na Memória",
      "fontSize": 17,
      "strokeColor": "#e03131",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
