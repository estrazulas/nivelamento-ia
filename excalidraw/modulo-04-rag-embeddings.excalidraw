    {
      "id": "me4634f1436ee4569",
      "type": "text",
      "x": 60.99609375,
      "y": 166,
      "width": 360.546875,
      "height": 350,
      "text": "Fluxo:\n  Pergunta → LLM (memória interna)\n           → Resposta\n\n⚠️ Problemas:\n• Pode alucinar — não tem fonte externa\n• Informação desatualizada\n• Não conhece dados do seu domínio\n• Não consegue citar fontes\n\nAnalogia:\nAluno fazendo prova sem consulta —\nconfia só no que lembra. Se não\nlembrar, chuta (alucina).",
      "fontSize": 20,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 759176537,
      "updated": 1783706942998,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 43,
      "index": "a5",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "Fluxo:\n  Pergunta → LLM (memória interna)\n           → Resposta\n\n⚠️ Problemas:\n• Pode alucinar — não tem fonte externa\n• Informação desatualizada\n• Não conhece dados do seu domínio\n• Não consegue citar fontes\n\nAnalogia:\nAluno fazendo prova sem consulta —\nconfia só no que lembra. Se não\nlembrar, chuta (alucina)."
    },
