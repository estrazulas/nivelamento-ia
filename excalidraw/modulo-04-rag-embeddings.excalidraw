    {
      "id": "m2916f1a3141b44ee",
      "type": "text",
      "x": 60,
      "y": 1895,
      "width": 250.55999999999997,
      "height": 24.3,
      "text": "🔍 Progressive Disclosure",
      "fontSize": 18,
      "strokeColor": "#fd7e14",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
