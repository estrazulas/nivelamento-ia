      "width": 250.55999999999997,
      "height": 24.3,
      "text": "🔍 Progressive Disclosure",
      "fontSize": 18,
      "strokeColor": "#fd7e14",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
