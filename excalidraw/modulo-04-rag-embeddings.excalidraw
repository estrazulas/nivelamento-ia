      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 47283991,
      "updated": 1783706760531,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 2,
      "index": "aa",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "🔧 Debugging: Resposta ruim? Verifique:"
    },
    {
      "id": "mf6a495038a93417d",
      "type": "text",
      "x": 1160,
      "y": 340,
      "width": 769.4915046296292,
      "height": 81.41171874999996,
      "text": "• Chunk mal dimensionado (muito grande → perde precisão; muito pequeno → perde contexto)\n• Embedding de baixa qualidade (modelo errado para o domínio)\n• Threshold de similaridade errado (chunks irrelevantes sendo injetados)\n• Top-K mal calibrado (poucos chunks → falta contexto; muitos chunks → poluição)",
      "fontSize": 15.076244212962962,
      "strokeColor": "#1e1e1e",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": [],
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
      "locked": false,
      "seed": 1,
      "versionNonce": 1186701881,
      "updated": 1783707128067,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "version": 22,
      "index": "ab",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "link": null,
      "containerId": null,
      "originalText": "• Chunk mal dimensionado (muito grande → perde precisão; muito pequeno → perde contexto)\n• Embedding de baixa qualidade (modelo errado para o domínio)\n• Threshold de similaridade errado (chunks irrelevantes sendo injetados)\n• Top-K mal calibrado (poucos chunks → falta contexto; muitos chunks → poluição)"
    },
