      "width": 177.48,
      "height": 24.3,
      "text": "📏 A Regra dos 40%",
      "fontSize": 18,
      "strokeColor": "#4c6ef5",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
