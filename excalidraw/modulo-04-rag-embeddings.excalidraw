    {
      "id": "m68c40775ec7f4eba",
      "type": "text",
      "x": 1160,
      "y": 312,
      "width": 330.59999999999997,
      "height": 20.25,
      "text": "🔧 Debugging: Resposta ruim? Verifique:",
      "fontSize": 15,
      "strokeColor": "#e03131",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
