    {
      "id": "m4f3f9f1a3b6d458f",
      "type": "text",
      "x": 530,
      "y": 135,
      "width": 295.79999999999995,
      "height": 22.950000000000003,
      "text": "✅ Com RAG — Contexto Relevante",
      "fontSize": 17,
      "strokeColor": "#2f9e44",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "autoResize": true,
      "lineHeight": 1.25,
      "angle": 0,
      "opacity": 100,
      "roughness": 0,
      "roundness": null,
      "boundElements": null,
      "groupIds": [],
      "frameId": null,
      "isDeleted": false,
