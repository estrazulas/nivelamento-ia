      "width": 330.59999999999997,
      "height": 20.25,
      "text": "🔧 Debugging: Resposta ruim? Verifique:",
      "fontSize": 15,
      "strokeColor": "#e03131",
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
